# =============================================================
# Libratio Fleet — Safe Configuration Template
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER put real secrets in this file.

# --- LLM Provider (Groq — default) ---
# Free API keys: https://console.groq.com/keys
HF_TOKEN=your_huggingface_token_here
GROQ_API_KEY=your_groq_api_key_here
API_BASE_URL=https://api.groq.com/openai/v1
MODEL_NAME=llama-3.1-8b-instant

# --- HuggingFace Custom Model (optional) ---
# Fine-tuned Libratio Fleet model for fleet_precision + fleet_recovery tasks
HF_MODEL_URL=https://router.huggingface.co/v1/chat/completions
HF_MODEL_NAME=SnippyCodes/libratio-fleet-llama3-grpo:featherless-ai

# --- Google AI (Gemini) ---
# Used for Atlas Vector Search embeddings AND Google ADK agent
# Free API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google ADK / Agent Builder ---
# ADK can run in two modes:
#   1. AI Studio (free): just set GEMINI_API_KEY above, leave GOOGLE_GENAI_USE_VERTEXAI=FALSE
#   2. Vertex AI (GCP): set GOOGLE_GENAI_USE_VERTEXAI=TRUE + project/location below
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ADK model to use (gemini-2.0-flash is fast and free-tier friendly)
ADK_MODEL=gemini-2.0-flash

# --- MongoDB Atlas ---
# Connection string from Atlas UI → Connect → Drivers
# Required for: Vector Search RAG, telemetry logging, analytics, MongoDB MCP Server
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# --- Environment Server ---
ENV_URL=http://localhost:7860

# --- App Config ---
ENV=development
HOST=127.0.0.1
PORT=7860
LOG_LEVEL=info
