# --- Secrets (NEVER commit) ---
.env
*.env.local
*.env.*.local

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# --- Logs & temp ---
*.log
*.tmp
*.bak

# --- Safe to commit ---
# .env.example  ← intentionally NOT ignored (it's the safe template)
