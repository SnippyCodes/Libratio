   "outputs": [],
   "source": [
    "# 8. Define Reward Function\n",
    "import httpx\n",
    "import json\n",
    "\n",
    "def fleet_oversight_reward(prompts, completions, **kwargs):\n",
    "    rewards = []\n",
    "    for prompt, completion in zip(prompts, completions):\n",
    "        try:\n",
    "            action_text = completion[0][\"content\"] if isinstance(completion[0], dict) else str(completion[0])\n",
    "            \n",
    "            # Extract JSON\n",
    "            if \"```json\" in action_text:\n",
    "                action_text = action_text.split(\"```json\")[1].split(\"```\")[0]\n",
    "            elif \"```\" in action_text:\n",
    "                action_text = action_text.split(\"```\")[1].split(\"```\")[0]\n",
    "            \n",
    "            action = json.loads(action_text)\n",
    "            \n",
    "            # Get environment feedback\n",
    "            reset_res = httpx.post(\"http://127.0.0.1:7860/fleet/reset\", json={\"task_id\": \"fleet_oversight\"}, timeout=10)\n",
    "            step_res = httpx.post(\"http://127.0.0.1:7860/fleet/step\", json={\"action\": action}, timeout=10)\n",
    "            \n",
    "            result = step_res.json()\n",
    "            score = result.get(\"reward\", {}).get(\"score\", 0.01)\n",
    "            rewards.append(max(0.01, min(1.0, score)))\n",
    "        except Exception as e:\n",
    "            rewards.append(0.01)\n",
    "    return rewards"
   ]
  },
  {
   "cell_type": "code",
