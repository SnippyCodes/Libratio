   "source": [
    "# 3. Create environment files inline if repo not available\n",
    "import os\n",
    "import json\n",
    "\n",
    "os.makedirs(\"/content/environment\", exist_ok=True)\n",
    "os.makedirs(\"/content/scenarios\", exist_ok=True)\n",
    "os.makedirs(\"/content/server\", exist_ok=True)\n",
    "\n",
    "# Write physics_model.py\n",
    "physics_model_code = '''\"\"\"Physics-based benchmark constants for Libratio Fleet.\"\"\"\n",
    "import numpy as np\n",
    "\n",
    "# Empirical benchmarks from Kalamkar et al. (2019), NVIDIA Transformer Engine (2023)\n",
    "PRECISION_SPEEDUPS = {\n",
    "    \"FP32\": {\"attn\": 1.0, \"ffn\": 1.0, \"emb\": 1.0},\n",
    "    \"FP16\": {\"attn\": 1.85, \"ffn\": 1.0, \"emb\": 1.0},\n",
    "    \"BF16\": {\"attn\": 1.85, \"ffn\": 1.25, \"emb\": 1.0},\n",
    "    \"FP8\": {\"attn\": 2.0, \"ffn\": 2.5, \"emb\": 0.5},  # 0.5 = crashes\n",
    "    \"FP8E4M3\": {\"attn\": 2.0, \"ffn\": 2.5, \"emb\": 0.5},\n",
    "    \"FP8E5M2\": {\"attn\": 2.0, \"ffn\": 2.5, \"emb\": 0.5},\n",
    "}\n",
    "\n",
    "LAYER_MEMORY_FP = {\n",
    "    \"FP32\": 4, \"FP16\": 2, \"BF16\": 2, \"FP8\": 1, \"FP8E4M3\": 1, \"FP8E5M2\": 1\n",
    "}\n",
    "\n",
    "def compute_model_memory(params: int, precision: str, n_layers: int) -> float:\n",
    "    \"\"\"Compute memory in GB for model weights given precision.\"\"\"\n",
    "    bytes_per_param = LAYER_MEMORY_FP.get(precision, 4)\n",
    "    return (params * bytes_per_param) / (1024 ** 3)\n",
    "\n",
    "def compute_layer_memory(layer_params: int, precision: str) -> float:\n",
    "    \"\"\"Compute memory in GB for a single layer.\"\"\"\n",
    "    bytes_per_param = LAYER_MEMORY_FP.get(precision, 4)\n",
    "    return (layer_params * bytes_per_param) / (1024 ** 3)\n",
    "\n",
    "def is_safe_precision(precision: str, layer_type: str) -> bool:\n",
    "    \"\"\"Check if precision is safe for given layer type.\"\"\"\n",
    "    if precision in [\"FP8\", \"FP8E4M3\", \"FP8E5M2\"]:\n",
    "        return layer_type not in [\"embedding\", \"output\"]\n",
    "    if precision == \"FP16\":\n",
    "        return layer_type != \"output\"\n",
    "    return True\n",
    "'''\n",
    "\n",
    "with open(\"/content/environment/physics_model.py\", \"w\") as f:\n",
    "    f.write(physics_model_code)\n",
    "\n",
    "print(\"Created environment files\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
