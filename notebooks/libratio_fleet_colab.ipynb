   "outputs": [],
   "source": [
    "# 4. Start the Fleet Environment Server\n",
    "import subprocess\n",
    "import time\n",
    "import sys\n",
    "import threading\n",
    "\n",
    "# Create __init__.py files\n",
    "for d in [\"/content/environment\", \"/content/scenarios\", \"/content/server\"]:\n",
    "    with open(f\"{d}/__init__.py\", \"w\") as f:\n",
    "        f.write(\"\")\n",
    "\n",
    "# Write fleet_env.py inline\n",
    "fleet_env_code = '''\"\"\"Multi-agent GPU Fleet Management Environment.\"\"\"\n",
    "import numpy as np\n",
    "import random\n",
    "from typing import Any, Dict, Optional, Tuple\n",
    "from environment.physics_model import compute_layer_memory, is_safe_precision, LAYER_MEMORY_FP\n",
    "\n",
    "CLUSTER_CONFIG = {\n",
    "    \"total_gpus\": 8,\n",
    "    \"total_memory_gb\": 640,\n",
    "}\n",
    "\n",
    "MODEL_CONFIGS = {\n",
    "    \"model_a\": {\"name\": \"LLaMA-3-7B\", \"params\": 7_000_000_000, \"priority\": 3},\n",
    "    \"model_b\": {\"name\": \"LLaMA-3-13B\", \"params\": 13_000_000_000, \"priority\": 2},\n",
    "    \"model_c\": {\"name\": \"CodeLLaMA-7B\", \"params\": 7_000_000_000, \"priority\": 1},\n",
    "}\n",
    "\n",
    "LAYER_TYPES = [\"embedding\", \"attention\", \"ffn\", \"layernorm\", \"output\"]\n",
    "\n",
    "LAYER_PARAMS_RATIO = {\n",
    "    \"embedding\": 0.10,\n",
    "    \"attention\": 0.20,\n",
    "    \"ffn\": 0.60,\n",
    "    \"layernorm\": 0.02,\n",
    "    \"output\": 0.08,\n",
    "}\n",
    "\n",
    "class FleetEnv:\n",
    "    \"\"\"Multi-agent GPU Fleet Management Environment.\"\"\"\n",
    "\n",
    "    def __init__(self, task_id: str = \"fleet_precision\"):\n",
    "        self.task_id = task_id\n",
    "        self.state = {}\n",
    "        self._reset()\n",
    "\n",
    "    def _reset(self) -> Dict[str, Any]:\n",
    "        \"\"\"Reset environment and return initial observation.\"\"\"\n",
    "        if self.task_id == \"fleet_precision\":\n",
    "            self.state = self._reset_precision()\n",
    "        elif self.task_id == \"fleet_oversight\":\n",
    "            self.state = self._reset_oversight()\n",
    "        elif self.task_id == \"fleet_resource\":\n",
    "            self.state = self._reset_resource()\n",
    "        elif self.task_id == \"fleet_recovery\":\n",
    "            self.state = self._reset_recovery()\n",
    "        return self.state\n",
    "\n",
    "    def _reset_precision(self) -> Dict[str, Any]:\n",
    "        \"\"\"Reset fleet precision task.\"\"\"\n",
    "        other_memory = random.uniform(20, 80)\n",
    "        return {\n",
    "            \"task_id\": \"fleet_precision\",\n",
    "            \"cluster\": {\n",
    "                \"total_gpus\": CLUSTER_CONFIG[\"total_gpus\"],\n",
    "                \"total_memory_gb\": CLUSTER_CONFIG[\"total_memory_gb\"],\n",
    "                \"memory_remaining_gb\": CLUSTER_CONFIG[\"total_memory_gb\"] - other_memory,\n",
    "            },\n",
    "            \"your_model\": {\n",
    "                \"model_id\": random.choice([\"model_a\", \"model_b\", \"model_c\"]),\n",
    "                \"name\": \"LLaMA-3-7B\",\n",
    "                \"total_params\": 7_000_000_000,\n",
    "                \"priority\": 3,\n",
    "            },\n",
    "            \"other_agents\": {\n",
    "                \"model_b\": {\"memory_used_gb\": other_memory, \"status\": \"configured\"},\n",
    "            },\n",
    "            \"agents_remaining\": 1,\n",
    "            \"_memory_used_gb\": other_memory,\n",
    "        }\n",
    "\n",
    "    def _reset_oversight(self) -> Dict[str, Any]:\n",
    "        \"\"\"Reset fleet oversight task.\"\"\"\n",
    "        models = [\"model_a\", \"model_b\", \"model_c\"]\n",
    "        crashed = random.choice(models)\n",
    "        trajectories = {}\n",
    "        \n",
    "        for model in models:\n",
    "            if model == crashed:\n",
    "                loss = [2.50, 2.30, None, None]  # NaN crash\n",
    "                prec = {\"embedding\": \"FP8\", \"attention\": \"BF16\"}  # Bad config\n",
    "            else:\n",
    "                loss = [round(2.0 + random.uniform(-0.5, 0.5), 2) for _ in range(4)]\n",
    "                prec = {\"embedding\": \"FP32\", \"attention\": \"BF16\"}\n",
    "            trajectories[model] = {\"loss_window\": loss, \"precision_config\": prec}\n",
    "        \n",
    "        return {\n",
    "            \"task_id\": \"fleet_oversight\",\n",
    "            \"model_trajectories\": trajectories,\n",
    "            \"windows_remaining\": 3,\n",
    "            \"_correct_model\": crashed,\n",
    "        }\n",
    "\n",
    "    def _reset_resource(self) -> Dict[str, Any]:\n",
    "        \"\"\"Reset fleet resource task.\"\"\"\n",
    "        return {\n",
    "            \"task_id\": \"fleet_resource\",\n",
    "            \"cluster\": {\n",
    "                \"total_gpus\": 8,\n",
    "                \"total_memory_gb\": 640,\n",
    "            },\n",
    "            \"models\": MODEL_CONFIGS,\n",
    "            \"_allocated\": {},\n",
    "        }\n",
    "\n",
    "    def _reset_recovery(self) -> Dict[str, Any]:\n",
    "        \"\"\"Reset fleet recovery task.\"\"\"\n",
    "        crashed = random.choice([\"model_a\", \"model_b\", \"model_c\"])\n",
    "        return {\n",
    "            \"task_id\": \"fleet_recovery\",\n",
    "            \"crashed_model\": crashed,\n",
    "            \"loss_trajectory\": [2.5, 2.3, 8.5, None],  # Crash at step 4\n",
    "            \"precision_config\": {\"embedding\": \"FP8\", \"attention\": \"BF16\", \"ffn\": \"FP8\", \"layernorm\": \"BF16\", \"output\": \"FP16\"},\n",
    "            \"phase\": 1,\n",
    "            \"_correct_cause\": \"fp8_embedding_underflow\",\n",
    "        }\n",
    "\n",
    "    def step(self, action: Dict[str, Any]) -> Tuple[Dict, Dict, bool, Dict]:\n",
    "        \"\"\"Execute action and return (observation, reward, done, info).\"\"\"\n",
    "        if self.task_id == \"fleet_precision\":\n",
    "            return self._step_precision(action)\n",
    "        elif self.task_id == \"fleet_oversight\":\n",
    "            return self._step_oversight(action)\n",
    "        elif self.task_id == \"fleet_resource\":\n",
    "            return self._step_resource(action)\n",
    "        elif self.task_id == \"fleet_recovery\":\n",
    "            return self._step_recovery(action)\n",
    "        return {}, {\"score\": 0.01, \"feedback\": \"unknown task\"}, True, {}\n",
    "\n",
    "    def _step_precision(self, action: Dict) -> Tuple[Dict, Dict, bool, Dict]:\n",
    "        \"\"\"Step for precision assignment task.\"\"\"\n",
    "        strategy = action.get(\"precision_strategy\", {})\n",
    "        score = 0.0\n",
    "        feedback = []\n",
    "        \n",
    "        for layer, prec in strategy.items():\n",
    "            if is_safe_precision(prec, layer):\n",
    "                score += 0.15\n",
    "            else:\n",
    "                feedback.append(f\"{prec} on {layer} is unsafe\")\n",
    "        \n",
    "        # Check memory usage\n",
    "        total_mem = sum(\n",
    "            compute_layer_memory(7_000_000_000 * LAYER_PARAMS_RATIO.get(lt, 0.2), p)\n",
    "            for lt, p in strategy.items()\n",
    "        )\n",
    "        \n",
    "        remaining = self.state.get(\"cluster\", {}).get(\"memory_remaining_gb\", 640)\n",
    "        if total_mem <= remaining:\n",
    "            score += 0.25\n",
    "        \n",
    "        done = True\n",
    "        score = min(1.0, score)\n",
    "        feedback_str = \"; \".join(feedback) if feedback else \"optimal config\"\n",
    "        \n",
    "        return self.state, {\"score\": score, \"feedback\": feedback_str}, done, {\"memory_used\": total_mem}\n",
    "\n",
    "    def _step_oversight(self, action: Dict) -> Tuple[Dict, Dict, bool, Dict]:\n",
    "        \"\"\"Step for fleet oversight task.\"\"\"\n",
    "        action_type = action.get(\"action_type\", \"continue_monitoring\")\n",
    "        flagged = action.get(\"flagged_model\")\n",
    "        correct = self.state[\"_correct_model\"]\n",
    "        \n",
    "        if action_type == \"continue_monitoring\":\n",
    "            score = 0.55\n",
    "            feedback = \"healthy fleet, continuing monitoring\"\n",
    "        elif flagged == correct:\n",
    "            score = 1.0\n",
    "            feedback = f\"correctly flagged {flagged} as crashing\"\n",
    "        else:\n",
    "            score = 0.10\n",
    "            feedback = f\"false alarm: {flagged} is not crashing\" if flagged else \"no flag\"\n",
    "        \n",
    "        done = True\n",
    "        return self.state, {\"score\": score, \"feedback\": feedback}, done, {\"correct_model\": correct}\n",
    "\n",
    "    def _step_resource(self, action: Dict) -> Tuple[Dict, Dict, bool, Dict]:\n",
    "        \"\"\"Step for resource allocation task.\"\"\"\n",
    "        allocations = action.get(\"allocations\", {})\n",
    "        score = 0.0\n",
    "        \n",
    "        total_gpus = sum(a.get(\"gpus\", 0) for a in allocations.values())\n",
    "        if total_gpus <= 8:\n",
    "            score += 0.3\n",
    "        \n",
    "        for model_id, alloc in allocations.items():\n",
    "            if alloc.get(\"gpus\", 0) >= 1:\n",
    "                score += 0.15\n",
    "        \n",
    "        done = True\n",
    "        score = min(1.0, score)\n",
    "        return self.state, {\"score\": score, \"feedback\": f\"allocated {total_gpus} GPUs\"}, done, {}\n",
    "\n",
    "    def _step_recovery(self, action: Dict) -> Tuple[Dict, Dict, bool, Dict]:\n",
    "        \"\"\"Step for recovery task.\"\"\"\n",
    "        phase = self.state.get(\"phase\", 1)\n",
    "        score = 0.0\n",
    "        feedback = \"\"\n",
    "        \n",
    "        if phase == 1:\n",
    "            diagnosed = action.get(\"diagnosed_model\", \"\")\n",
    "            cause = action.get(\"root_cause\", \"\")\n",
    "            if diagnosed == self.state.get(\"crashed_model\") and \"fp8\" in cause.lower():\n",
    "                score = 1.0\n",
    "                feedback = \"correct diagnosis\"\n",
    "            else:\n",
    "                score = 0.3\n",
    "                feedback = \"incorrect diagnosis\"\n",
    "            self.state[\"phase\"] = 2\n",
    "            done = False\n",
    "        elif phase == 2:\n",
    "            new_strategy = action.get(\"new_precision_strategy\", {})\n",
    "            if new_strategy.get(\"embedding\") == \"FP32\":\n",
    "                score = 1.0\n",
    "                feedback = \"safe strategy proposed\"\n",
    "            else:\n",
    "                score = 0.3\n",
    "                feedback = \"unsafe strategy\"\n",
    "            self.state[\"phase\"] = 3\n",
    "            done = False\n",
    "        else:\n",
    "            score = 1.0\n",
    "            feedback = \"recovery verified\"\n",
    "            done = True\n",
    "        \n",
    "        return self.state, {\"score\": score, \"feedback\": feedback}, done, {}\n",
    "'''\n",
    "\n",
    "with open(\"/content/environment/fleet_env.py\", \"w\") as f:\n",
    "    f.write(fleet_env_code)\n",
    "\n",
    "print(\"Created fleet_env.py\")"
   ]
  },
