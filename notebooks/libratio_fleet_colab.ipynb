   "source": [
    "# 9. Generate Training Data\n",
    "from datasets import Dataset\n",
    "\n",
    "print(\"Generating training data...\")\n",
    "training_data = []\n",
    "\n",
    "for i in range(50):\n",
    "    try:\n",
    "        res = httpx.post(\"http://127.0.0.1:7860/fleet/reset\", json={\"task_id\": \"fleet_oversight\"}, timeout=10)\n",
    "        obs = res.json()[\"observation\"]\n",
    "        \n",
    "        prompt_text = json.dumps(obs, default=str)\n",
    "        training_data.append({\n",
    "            \"prompt\": [\n",
    "                {\"role\": \"system\", \"content\": \"You are a Fleet AI Oversight Agent. Monitor training runs and detect crashes. Output valid JSON.\"},\n",
    "                {\"role\": \"user\", \"content\": f\"Fleet state: {prompt_text[:2000]}\"}\n",
    "            ]\n",
    "        })\n",
    "    except Exception as e:\n",
    "        print(f\"Error generating sample {i}: {e}\")\n",
    "\n",
    "dataset = Dataset.from_list(training_data)\n",
    "print(f\"Created dataset with {len(training_data)} samples\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 10. Train with GRPO\n",
    "from trl import GRPOConfig, GRPOTrainer\n",
    "\n",
    "training_args = GRPOConfig(\n",
    "    output_dir=\"fleet_outputs\",\n",
    "    learning_rate=5e-6,\n",
    "    per_device_train_batch_size=2,\n",
    "    gradient_accumulation_steps=2,\n",
    "    max_steps=30,\n",
    "    logging_steps=5,\n",
    "    seed=42,\n",
    ")\n",
    "\n",
    "trainer = GRPOTrainer(\n",
    "    model=model,\n",
    "    reward_funcs=[fleet_oversight_reward],\n",
    "    args=training_args,\n",
    "    train_dataset=dataset,\n",
    ")\n",
    "\n",
    "print(\"Starting Fleet RL Training...\")\n",
    "trainer.train()\n",
    "print(\"Training complete!\")"
   ]
  },
  {
