    "# 5. Create the FastAPI server\n",
    "server_code = '''\"\"\"FastAPI server for Libratio Fleet.\"\"\"\n",
    "from fastapi import FastAPI, HTTPException\n",
    "from pydantic import BaseModel\n",
    "from typing import Any, Dict, Optional\n",
    "import uvicorn\n",
    "import threading\n",
    "import time\n",
    "import sys\n",
    "sys.path.insert(0, \"/content\")\n",
    "\n",
    "from environment.fleet_env import FleetEnv\n",
    "\n",
    "app = FastAPI(title=\"Libratio Fleet\")\n",
    "\n",
    "class ResetRequest(BaseModel):\n",
    "    task_id: str = \"fleet_precision\"\n",
    "\n",
    "class StepRequest(BaseModel):\n",
    "    action: Dict[str, Any]\n",
    "\n",
    "env_instances: Dict[str, FleetEnv] = {}\n",
    "\n",
    "@app.post(\"/fleet/reset\")\n",
    "async def reset(req: ResetRequest):\n",
    "    \"\"\"Reset the fleet environment.\"\"\"\n",
    "    env = FleetEnv(task_id=req.task_id)\n",
    "    obs = env._reset()\n",
    "    session_id = f\"session_{id(env)}\"\n",
    "    env_instances[session_id] = env\n",
    "    return {\"observation\": obs, \"session_id\": session_id}\n",
    "\n",
    "@app.post(\"/fleet/step\")\n",
    "async def step(req: StepRequest, session_id: Optional[str] = None):\n",
    "    \"\"\"Execute a step in the environment.\"\"\"\n",
    "    if session_id and session_id in env_instances:\n",
    "        env = env_instances[session_id]\n",
    "    else:\n",
    "        env = FleetEnv()\n",
    "    obs, reward, done, info = env.step(req.action)\n",
    "    return {\"observation\": obs, \"reward\": reward, \"done\": done, \"info\": info}\n",
    "\n",
    "@app.get(\"/fleet/tasks\")\n",
    "async def get_tasks():\n",
    "    \"\"\"Get available fleet tasks.\"\"\"\n",
    "    return {\n",
    "        \"tasks\": [\n",
    "            {\"id\": \"fleet_precision\", \"name\": \"Fleet Precision Assignment\"},\n",
    "            {\"id\": \"fleet_oversight\", \"name\": \"Fleet Oversight Monitoring\"},\n",
    "            {\"id\": \"fleet_resource\", \"name\": \"Fleet Resource Negotiation\"},\n",
    "            {\"id\": \"fleet_recovery\", \"name\": \"Fleet Recovery\"},\n",
    "        ]\n",
    "    }\n",
    "\n",
    "@app.get(\"/\")\n",
    "async def root():\n",
    "    return {\"message\": \"Libratio Fleet API\", \"version\": \"1.0.0\"}\n",
    "\n",
    "def start_server():\n",
    "    \"\"\"Start the uvicorn server.\"\"\"\n",
    "    uvicorn.run(app, host=\"127.0.0.1\", port=7860, log_level=\"warning\")\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    start_server()\n",
    "'''\n",
    "\n",
    "with open(\"/content/server/app.py\", \"w\") as f:\n",
    "    f.write(server_code)\n",
    "\n",
    "print(\"Created server/app.py\")"
   ]
  },
